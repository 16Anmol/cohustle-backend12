# ─────────────────────────────────────────────────────────────
# CoHustle Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB — Atlas URI or local replica set
# Database name: cohustle
# Collections auto-created by Mongoose: users, freelancerprofiles, startupprofiles,
#                                        problems, applications, conversations, messages
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cohustle?retryWrites=true&w=majority

# JWT secret (any long random string)
JWT_SECRET=replace_with_a_long_random_secret_string

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (for CORS and OAuth redirect)
CLIENT_URL=http://localhost:5173

# Server port (optional, defaults to 5000)
PORT=5000
